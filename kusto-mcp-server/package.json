{
  "name": "kuskus-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing KQL language service tools — validate, format, complete, explain, execute",
  "keywords": [
    "kusto",
    "kql",
    "mcp",
    "language-server",
    "azure-data-explorer"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rosshamish/kuskus.git",
    "directory": "kusto-mcp-server"
  },
  "bin": {
    "kuskus-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit && eslint src",
    "lint:fix": "eslint --fix src",
    "test": "node --loader ts-node/esm --no-warnings node_modules/.bin/mocha 'src/test/**/*.test.ts'"
  },
  "dependencies": {
    "@kusto/language-service-next": "^11.7.1",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "azure-kusto-data": "^6.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
