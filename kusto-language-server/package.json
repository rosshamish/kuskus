{
    "name": "kuskus-kusto-language-server",
    "displayName": "[Kuskus] Kusto Language Server",
    "description": "Language server for the Kusto query language",
    "version": "3.4.2",
    "type": "module",
    "publisher": "rosshamish",
    "license": "Apache-2.0",
    "homepage": "https://github.com/rosshamish/kuskus",
    "repository": {
        "type": "git",
        "url": "https://github.com/rosshamish/kuskus"
    },
    "bugs": {
        "url": "https://github.com/rosshamish/kuskus/issues"
    },
    "engines": {
        "vscode": "^1.98.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters"
    ],
    "keywords": [
        "kusto",
        "language",
        "kuskus",
        "query",
        "azure data explorer",
        "azure",
        "csl",
        "kql"
    ],
    "activationEvents": [
        "onLanguage:kusto",
        "onCommand:kuskus.loadSymbols",
        "onCommand:kuskus.login"
    ],
    "main": "./client/out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "kusto",
                "aliases": [
                    "Kusto",
                    "kusto"
                ],
                "extensions": [
                    ".csl",
                    ".kusto",
                    ".kql"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "[Kuskus] Kusto",
            "properties": {
                "kuskusLanguageServer.diagnosticsEnabled": {
                    "scope": "resource",
                    "type": "boolean",
                    "default": false,
                    "description": "Whether diagnostics are enabled or not (red squiggly underlines, Problems tab)"
                }
            }
        },
        "commands": [
            {
                "command": "kuskus.loadSymbols",
                "title": "[Kuskus] Load Symbols from Cluster"
            },
            {
                "command": "kuskus.login",
                "title": "[Kuskus] Login to Cluster"
            },
            {
                "command": "kuskus.runScript",
                "title": "[Kuskus] Run Script"
            },
            {
                "command": "kuskus.setActiveDatabase",
                "title": "[Kuskus] Set as Active Database"
            },
            {
                "command": "kuskus.refreshCluster",
                "title": "[Kuskus] Refresh Cluster",
                "icon": "$(refresh)"
            }
        ],
        "menus": {
            "view/item/context": [
                {
                    "command": "kuskus.setActiveDatabase",
                    "when": "view == kuskus-clusters && viewItem == database",
                    "group": "inline"
                },
                {
                    "command": "kuskus.refreshCluster",
                    "when": "view == kuskus-clusters && viewItem == cluster",
                    "group": "inline"
                }
            ]
        },
        "keybindings": [
            {
                "command": "kuskus.runScript",
                "key": "shift+enter",
                "when": "editorTextFocus && editorLangId == kusto"
            },
            {
                "command": "kuskus.addNewLine",
                "key": "ctrl+enter",
                "when": "editorTextFocus && editorLangId == kusto"
            }
        ],
        "languageModelTools": [
            {
                "name": "run_kusto_query",
                "displayName": "Run Kusto query",
                "canBeReferencedInPrompt": true,
                "toolReferenceName": "kuskus-run-kusto-query",
                "icon": "resources/kusto-logo-new-2.svg",
                "userDescription": "Run Kusto query",
                "modelDescription": "Run a Kusto query against the active database. Input should be a JSON object with a 'query' property containing the Kusto query to run. Output will be a JSON object with either a 'result' property containing the query results or an 'error' property containing an error message if the query failed.",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "description": "The Kusto query to run"
                        }
                    },
                    "required": ["query"]
                },
                "when": "kuskus.hasActiveDatabase"
            },
            {
                "name": "list_databases",
                "displayName": "List Kusto databases",
                "canBeReferencedInPrompt": true,
                "toolReferenceName": "kuskus-list-databases",
                "icon": "resources/kusto-logo-new-2.svg",
                "userDescription": "List databases in a connected Kusto cluster",
                "modelDescription": "List all databases in a connected Kusto cluster. Input should be a JSON object with a 'clusterUri' property containing the full cluster URI (e.g. 'https://help.kusto.windows.net'). The cluster must already be connected in the Kusto Explorer panel. Output is a JSON array of objects with 'name' and 'prettyName' properties for each database.",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "clusterUri": {
                            "type": "string",
                            "description": "The full URI of the connected Kusto cluster (e.g. 'https://help.kusto.windows.net')"
                        }
                    },
                    "required": ["clusterUri"]
                },
                "when": "kuskus.hasConnectedClusters"
            },
            {
                "name": "list_tables",
                "displayName": "List Kusto tables",
                "canBeReferencedInPrompt": true,
                "toolReferenceName": "kuskus-list-tables",
                "icon": "resources/kusto-logo-new-2.svg",
                "userDescription": "List tables in the active Kusto database",
                "modelDescription": "List all tables in the currently active Kusto database. Takes no input parameters. The user must have an active database selected in the Kusto Explorer panel. Output is a JSON array of table name strings.",
                "inputSchema": {
                    "type": "object",
                    "properties": {}
                },
                "when": "kuskus.hasActiveDatabase"
            },
            {
                "name": "get_table_schema",
                "displayName": "Get Kusto table schema",
                "canBeReferencedInPrompt": true,
                "toolReferenceName": "kuskus-get-table-schema",
                "icon": "resources/kusto-logo-new-2.svg",
                "userDescription": "Get the column names and types for a table in the active Kusto database",
                "modelDescription": "Get the schema (column names and types) of a specific table in the currently active Kusto database. Input should be a JSON object with a 'tableName' property. The user must have an active database selected. Output is a JSON array of objects with 'name' and 'type' properties for each column.",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "tableName": {
                            "type": "string",
                            "description": "The name of the table to get the schema for"
                        }
                    },
                    "required": ["tableName"]
                },
                "when": "kuskus.hasActiveDatabase"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "kuskus-explorer",
                    "title": "Kusto Explorer",
                    "icon": "resources/kusto-logo-new-2.svg"
                }
            ],
            "panel": [
                {
                    "id": "kuskus-results-panel",
                    "title": "Kusto Results",
                    "icon": "resources/kusto-logo-new-2.svg"
                }
            ]
        },
        "views": {
            "kuskus-explorer": [
                {
                    "id": "kuskus-clusters",
                    "name": "Clusters"
                }
            ],
            "kuskus-results-panel": [
                {
                    "id": "kuskus-results",
                    "name": "Results",
                    "type": "webview"
                }
            ]
        }
    },
    "scripts": {
        "lint": "cd client && npm run lint && cd ../server && npm run lint && cd ..",
        "lint:fix": "cd client && npm run lint:fix && cd ../server && npm run lint:fix && cd ..",
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -b && tsc -p client/src/results-panel/tsconfig.json",
        "watch": "tsc -b -w",
        "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
        "test": "vscode-test",
        "test:unit": "cd client && npm run test:unit && cd ../server && npm run test:unit && cd .."
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.35.0",
        "@types/node": "^22.18.4",
        "@vscode/test-cli": "^0.0.12",
        "eslint": "^9.35.0",
        "globals": "^16.4.0",
        "tslint": "^6.1.3",
        "typescript": "^5.5.4"
    }
}
